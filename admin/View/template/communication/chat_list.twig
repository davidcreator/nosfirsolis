{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <a href="{{ add }}" data-bs-toggle="tooltip" title="{{ button_add }}" class="btn btn-primary"><i class="fa-solid fa-plus"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% set bulk_select_enabled = supports_operational_meta or supports_chat_routing %}
    {% set total_columns = 4 + (bulk_select_enabled ? 1 : 0) + (supports_operational_meta ? 3 : 0) + (supports_chat_routing ? 2 : 0) + (supports_chat_tags ? 1 : 0) + (supports_sla ? 1 : 0) + (supports_engagement ? 1 : 0) %}
    <div class="card">
      <div class="card-header"><i class="fa-solid fa-comment"></i> {{ text_list }}</div>
      <div class="card-body">
        {% if success %}
        <div class="alert alert-success alert-dismissible"><i class="fa-solid fa-check-circle"></i> {{ success }} <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        {% endif %}
        {% if warning %}
        <div class="alert alert-danger alert-dismissible"><i class="fa-solid fa-circle-exclamation"></i> {{ warning }} <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        {% endif %}

        {% if supports_operational_meta or supports_sla %}
        <div class="mb-4">
          <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
            <strong>{{ text_summary_title }}</strong>
            <span class="text-muted small">{{ text_summary_hint }}</span>
          </div>
          <div class="row g-3">
            <div class="col-sm-6 col-xl-2">
              <a href="{{ summary_links.visible }}" class="card h-100 text-decoration-none">
                <div class="card-body">
                  <div class="text-muted small">{{ text_summary_visible }}</div>
                  <div class="fs-3 fw-semibold">{{ chat_inbox_summary.visible_total }}</div>
                </div>
              </a>
            </div>
            {% if supports_operational_meta %}
            <div class="col-sm-6 col-xl-2">
              <div class="card h-100">
                <div class="card-body">
                  <div class="text-muted small">{{ text_summary_needs_team_action }}</div>
                  <div class="fs-3 fw-semibold">{{ chat_inbox_summary.needs_team_action_total }}</div>
                </div>
              </div>
            </div>
            <div class="col-sm-6 col-xl-2">
              <a href="{{ summary_links.waiting_customer }}" class="card h-100 text-decoration-none">
                <div class="card-body">
                  <div class="text-muted small">{{ text_summary_waiting_customer }}</div>
                  <div class="fs-3 fw-semibold">{{ chat_inbox_summary.waiting_customer_total }}</div>
                </div>
              </a>
            </div>
            <div class="col-sm-6 col-xl-2">
              <a href="{{ summary_links.unassigned }}" class="card h-100 text-decoration-none">
                <div class="card-body">
                  <div class="text-muted small">{{ text_summary_unassigned }}</div>
                  <div class="fs-3 fw-semibold">{{ chat_inbox_summary.unassigned_total }}</div>
                </div>
              </a>
            </div>
            {% endif %}
            {% if supports_sla %}
            <div class="col-sm-6 col-xl-2">
              <a href="{{ summary_links.sla_due_soon }}" class="card h-100 text-decoration-none">
                <div class="card-body">
                  <div class="text-muted small">{{ text_summary_sla_due_soon }}</div>
                  <div class="fs-3 fw-semibold">{{ chat_inbox_summary.sla_due_soon_total }}</div>
                </div>
              </a>
            </div>
            <div class="col-sm-6 col-xl-2">
              <a href="{{ summary_links.sla_breached }}" class="card h-100 text-decoration-none">
                <div class="card-body">
                  <div class="text-muted small">{{ text_summary_sla_breached }}</div>
                  <div class="fs-3 fw-semibold">{{ chat_inbox_summary.sla_breached_total }}</div>
                </div>
              </a>
            </div>
            {% endif %}
          </div>
        </div>
        {% endif %}

        {% if can_supervise %}
        <div class="card mb-4">
          <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
            <span><i class="fa-solid fa-chart-line"></i> {{ text_supervisor_dashboard_title }}</span>
            <span class="text-muted small">{{ text_supervisor_dashboard_hint }}</span>
          </div>
          <div class="card-body">
            {% if supervisor_dashboard.scope_notice %}
            <div class="alert alert-warning py-2 mb-3">
              <i class="fa-solid fa-triangle-exclamation"></i> {{ supervisor_dashboard.scope_notice }}
            </div>
            {% endif %}

            {% if supervisor_dashboard.has_data %}
            <div class="mb-4">
              <div class="small fw-semibold mb-2">{{ text_supervisor_sla_mix }}</div>
              <div class="d-flex flex-wrap gap-2">
                {% for item in supervisor_dashboard.sla_mix %}
                <span class="badge {{ item.badge_class }}">{{ item.label }}: {{ item.total }}</span>
                {% endfor %}
              </div>
            </div>

            <div class="row g-3">
              <div class="col-xl-4">
                <div class="border rounded h-100">
                  <div class="px-3 py-2 border-bottom bg-light fw-semibold">{{ text_supervisor_department_pressure }}</div>
                  {% if supervisor_dashboard.departments %}
                  <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                      <thead>
                        <tr>
                          <th>{{ text_department }}</th>
                          <th class="text-end">{{ text_supervisor_active }}</th>
                          <th class="text-end">{{ text_summary_needs_team_action }}</th>
                          <th class="text-end">{{ text_supervisor_at_risk }}</th>
                        </tr>
                      </thead>
                      <tbody>
                        {% for row in supervisor_dashboard.departments %}
                        <tr>
                          <td>
                            <a href="{{ row.href }}">{{ row.label }}</a>
                            <div class="text-muted small">{{ text_summary_waiting_customer }}: {{ row.waiting_customer_total }} &middot; {{ text_summary_unassigned }}: {{ row.unassigned_total }}</div>
                          </td>
                          <td class="text-end">{{ row.active_total }}</td>
                          <td class="text-end">{{ row.team_action_total }}</td>
                          <td class="text-end"><span class="badge {{ row.risk_badge_class }}">{{ row.at_risk_total }}</span></td>
                        </tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  </div>
                  {% else %}
                  <div class="p-3 text-muted">{{ text_supervisor_empty }}</div>
                  {% endif %}
                </div>
              </div>
              <div class="col-xl-4">
                <div class="border rounded h-100">
                  <div class="px-3 py-2 border-bottom bg-light fw-semibold">{{ text_supervisor_queue_pressure }}</div>
                  {% if supervisor_dashboard.queues %}
                  <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                      <thead>
                        <tr>
                          <th>{{ text_queue }}</th>
                          <th class="text-end">{{ text_supervisor_active }}</th>
                          <th class="text-end">{{ text_summary_needs_team_action }}</th>
                          <th class="text-end">{{ text_supervisor_at_risk }}</th>
                        </tr>
                      </thead>
                      <tbody>
                        {% for row in supervisor_dashboard.queues %}
                        <tr>
                          <td>
                            <a href="{{ row.href }}">{{ row.label }}</a>
                            <div class="text-muted small">{{ text_summary_waiting_customer }}: {{ row.waiting_customer_total }} &middot; {{ text_summary_unassigned }}: {{ row.unassigned_total }}</div>
                          </td>
                          <td class="text-end">{{ row.active_total }}</td>
                          <td class="text-end">{{ row.team_action_total }}</td>
                          <td class="text-end"><span class="badge {{ row.risk_badge_class }}">{{ row.at_risk_total }}</span></td>
                        </tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  </div>
                  {% else %}
                  <div class="p-3 text-muted">{{ text_supervisor_empty }}</div>
                  {% endif %}
                </div>
              </div>
              <div class="col-xl-4">
                <div class="border rounded h-100">
                  <div class="px-3 py-2 border-bottom bg-light fw-semibold">{{ text_supervisor_agent_workload }}</div>
                  {% if supervisor_dashboard.agents %}
                  <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                      <thead>
                        <tr>
                          <th>{{ text_assignee }}</th>
                          <th class="text-end">{{ text_supervisor_active }}</th>
                          <th class="text-end">{{ text_summary_needs_team_action }}</th>
                          <th class="text-end">{{ text_supervisor_at_risk }}</th>
                        </tr>
                      </thead>
                      <tbody>
                        {% for row in supervisor_dashboard.agents %}
                        <tr>
                          <td>
                            <a href="{{ row.href }}">{{ row.label }}</a>
                            <div class="text-muted small">{{ text_summary_waiting_customer }}: {{ row.waiting_customer_total }} &middot; {{ text_summary_unassigned }}: {{ row.unassigned_total }}</div>
                          </td>
                          <td class="text-end">{{ row.active_total }}</td>
                          <td class="text-end">{{ row.team_action_total }}</td>
                          <td class="text-end"><span class="badge {{ row.risk_badge_class }}">{{ row.at_risk_total }}</span></td>
                        </tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  </div>
                  {% else %}
                  <div class="p-3 text-muted">{{ text_supervisor_empty }}</div>
                  {% endif %}
                </div>
              </div>
            </div>
            {% else %}
            <div class="text-muted">{{ text_supervisor_empty }}</div>
            {% endif %}
          </div>
        </div>

        <div class="card mb-4">
          <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
            <span><i class="fa-solid fa-chart-column"></i> {{ text_supervisor_trends_title }}</span>
            <div class="d-flex flex-wrap align-items-center gap-2">
              <span class="text-muted small">{{ supervisor_trends.hint }}</span>
              <form action="{{ reset|replace({'&amp;':'&'}) }}" method="get" class="d-flex flex-wrap align-items-center gap-2">
                <input type="hidden" name="filter_scope" value="{{ chat_filters.filter_scope }}">
                <input type="hidden" name="filter_status" value="{{ chat_filters.filter_status }}">
                <input type="hidden" name="filter_priority" value="{{ chat_filters.filter_priority }}">
                <input type="hidden" name="filter_department_id" value="{{ chat_filters.filter_department_id }}">
                <input type="hidden" name="filter_queue_id" value="{{ chat_filters.filter_queue_id }}">
                <input type="hidden" name="filter_assigned_user_id" value="{{ chat_filters.filter_assigned_user_id }}">
                <input type="hidden" name="filter_sla_state" value="{{ chat_filters.filter_sla_state }}">
                <input type="hidden" name="filter_tag" value="{{ chat_filters.filter_tag }}">
                <label class="form-label small mb-0" for="input-trend-window">{{ text_supervisor_trends_window_label }}</label>
                <select name="trend_window_days" id="input-trend-window" class="form-select form-select-sm">
                  {% for option in trend_window_options %}
                  <option value="{{ option }}"{% if supervisor_trends.window_days == option %} selected{% endif %}>{{ option }}</option>
                  {% endfor %}
                </select>
                <button type="submit" class="btn btn-sm btn-outline-secondary">{{ button_filter }}</button>
                <a href="{{ analytics_export }}" class="btn btn-sm btn-outline-primary">{{ button_export_csv }}</a>
              </form>
            </div>
          </div>
          <div class="card-body">
            {% if supervisor_trends.has_data %}
            <div class="row g-3 mb-4">
              {% for metric in supervisor_trends.metrics %}
              <div class="col-sm-6 col-xl-3">
                <div class="card h-100">
                  <div class="card-body">
                    <div class="text-muted small">{{ metric.label }}</div>
                    <div class="fs-4 fw-semibold">{{ metric.current_total }}</div>
                    <div class="text-muted small">{{ supervisor_trends.window_label }}</div>
                    <div class="small mt-2">{{ supervisor_trends.previous_label }}: {{ metric.previous_total }}</div>
                    <div class="mt-2">
                      <span class="badge {{ metric.difference_badge_class }}">{{ text_supervisor_trends_difference }}: {{ metric.difference_label }}</span>
                    </div>
                  </div>
                </div>
              </div>
              {% endfor %}
            </div>

            <div class="row g-3">
              <div class="col-xl-7">
                <div class="border rounded h-100">
                  <div class="px-3 py-2 border-bottom bg-light fw-semibold">{{ text_supervisor_trends_daily }}</div>
                  <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                      <thead>
                        <tr>
                          <th>{{ column_date }}</th>
                          <th class="text-end">{{ text_supervisor_trends_new_chats }}</th>
                          <th class="text-end">{{ text_supervisor_trends_resolved }}</th>
                          <th class="text-end">{{ text_supervisor_trends_customer_messages }}</th>
                          <th class="text-end">{{ text_supervisor_trends_admin_messages }}</th>
                        </tr>
                      </thead>
                      <tbody>
                        {% for row in supervisor_trends.daily %}
                        <tr>
                          <td>{{ row.day_label }}</td>
                          <td class="text-end">{{ row.new_chats_total }}</td>
                          <td class="text-end">{{ row.resolved_chats_total }}</td>
                          <td class="text-end">{{ row.customer_messages_total }}</td>
                          <td class="text-end">{{ row.admin_messages_total }}</td>
                        </tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
              <div class="col-xl-5">
                <div class="border rounded h-100">
                  <div class="px-3 py-2 border-bottom bg-light fw-semibold">{{ text_supervisor_trends_departments }}</div>
                  {% if supervisor_trends.departments %}
                  <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                      <thead>
                        <tr>
                          <th>{{ text_department }}</th>
                          <th class="text-end">{{ text_supervisor_trends_new_chats }}</th>
                          <th class="text-end">{{ text_supervisor_trends_resolved }}</th>
                          <th class="text-end">{{ text_supervisor_trends_customer_messages }}</th>
                          <th class="text-end">{{ text_supervisor_trends_admin_messages }}</th>
                        </tr>
                      </thead>
                      <tbody>
                        {% for row in supervisor_trends.departments %}
                        <tr>
                          <td><a href="{{ row.href }}">{{ row.label }}</a></td>
                          <td class="text-end">{{ row.new_chats_total }}</td>
                          <td class="text-end">{{ row.resolved_chats_total }}</td>
                          <td class="text-end">{{ row.customer_messages_total }}</td>
                          <td class="text-end">{{ row.admin_messages_total }}</td>
                        </tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  </div>
                  {% else %}
                  <div class="p-3 text-muted">{{ text_supervisor_trends_empty }}</div>
                  {% endif %}
                </div>
              </div>
            </div>
            {% else %}
            <div class="text-muted">{{ text_supervisor_trends_empty }}</div>
            {% endif %}
          </div>
        </div>

        {% if supports_analytics_archive %}
        <div class="card mb-4">
          <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
            <span><i class="fa-solid fa-database"></i> {{ text_supervisor_archive_title }}</span>
            <form action="{{ analytics_snapshot|replace({'&amp;':'&'}) }}" method="post" class="d-flex flex-wrap align-items-center gap-2">
              <input type="hidden" name="filter_scope" value="{{ chat_filters.filter_scope }}">
              <input type="hidden" name="filter_status" value="{{ chat_filters.filter_status }}">
              <input type="hidden" name="filter_priority" value="{{ chat_filters.filter_priority }}">
              <input type="hidden" name="filter_department_id" value="{{ chat_filters.filter_department_id }}">
              <input type="hidden" name="filter_queue_id" value="{{ chat_filters.filter_queue_id }}">
              <input type="hidden" name="filter_assigned_user_id" value="{{ chat_filters.filter_assigned_user_id }}">
              <input type="hidden" name="filter_sla_state" value="{{ chat_filters.filter_sla_state }}">
              <input type="hidden" name="filter_tag" value="{{ chat_filters.filter_tag }}">
              <input type="hidden" name="trend_window_days" value="{{ chat_filters.trend_window_days }}">
              <input type="hidden" name="page" value="{{ page }}">
              <span class="text-muted small">{{ text_supervisor_archive_hint }}</span>
              <button type="submit" class="btn btn-sm btn-outline-secondary">{{ button_capture_snapshot }}</button>
            </form>
          </div>
          <div class="card-body">
            <div class="alert alert-info py-2 mb-3">
              <i class="fa-solid fa-circle-info"></i> {{ text_supervisor_archive_scope_note }}
            </div>

            {% if archived_analytics.has_data %}
            <div class="small fw-semibold mb-3">
              {{ text_supervisor_archive_latest }}:
              <span class="text-muted">{{ archived_analytics.latest_snapshot_label }}</span>
            </div>

            <div class="row g-3">
              <div class="col-xl-7">
                <div class="border rounded h-100">
                  <div class="px-3 py-2 border-bottom bg-light fw-semibold">{{ text_supervisor_archive_recent }}</div>
                  <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                      <thead>
                        <tr>
                          <th>{{ column_date }}</th>
                          <th class="text-end">{{ text_supervisor_active }}</th>
                          <th class="text-end">{{ text_summary_needs_team_action }}</th>
                          <th class="text-end">{{ text_summary_waiting_customer }}</th>
                          <th class="text-end">{{ text_summary_sla_due_soon }}</th>
                          <th class="text-end">{{ text_summary_sla_breached }}</th>
                          <th class="text-end">{{ text_supervisor_trends_new_chats }}</th>
                          <th class="text-end">{{ text_supervisor_trends_resolved }}</th>
                          <th class="text-end">{{ text_supervisor_archive_captured_at }}</th>
                        </tr>
                      </thead>
                      <tbody>
                        {% for row in archived_analytics.snapshots %}
                        <tr>
                          <td>{{ row.snapshot_label }}</td>
                          <td class="text-end">{{ row.active_total }}</td>
                          <td class="text-end">{{ row.team_action_total }}</td>
                          <td class="text-end">{{ row.waiting_customer_total }}</td>
                          <td class="text-end">{{ row.sla_due_soon_total }}</td>
                          <td class="text-end">{{ row.sla_breached_total }}</td>
                          <td class="text-end">{{ row.new_chats_total }}</td>
                          <td class="text-end">{{ row.resolved_chats_total }}</td>
                          <td class="text-end">{{ row.captured_at_label }}</td>
                        </tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
              <div class="col-xl-5">
                <div class="border rounded h-100">
                  <div class="px-3 py-2 border-bottom bg-light fw-semibold">{{ text_supervisor_archive_departments }}</div>
                  {% if archived_analytics.departments %}
                  <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                      <thead>
                        <tr>
                          <th>{{ text_department }}</th>
                          <th class="text-end">{{ text_supervisor_active }}</th>
                          <th class="text-end">{{ text_supervisor_trends_new_chats }}</th>
                          <th class="text-end">{{ text_supervisor_trends_resolved }}</th>
                          <th class="text-end">{{ text_supervisor_trends_customer_messages }}</th>
                        </tr>
                      </thead>
                      <tbody>
                        {% for row in archived_analytics.departments %}
                        <tr>
                          <td><a href="{{ row.href }}">{{ row.label }}</a></td>
                          <td class="text-end">{{ row.active_total }}</td>
                          <td class="text-end">{{ row.new_chats_total }}</td>
                          <td class="text-end">{{ row.resolved_chats_total }}</td>
                          <td class="text-end">{{ row.customer_messages_total }}</td>
                        </tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  </div>
                  {% else %}
                  <div class="p-3 text-muted">{{ text_supervisor_archive_empty }}</div>
                  {% endif %}
                </div>
              </div>
            </div>
            {% else %}
            <div class="text-muted">{{ text_supervisor_archive_empty }}</div>
            {% endif %}
          </div>
        </div>
        {% endif %}

        <div class="row g-3 mb-4">
          <div class="col-xl-7">
            <div class="card h-100">
              <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fa-solid fa-robot"></i> {{ text_automation_title }}</span>
                <span class="badge {% if supports_chat_automation %}bg-success{% else %}bg-warning text-dark{% endif %}">
                  {% if supports_chat_automation %}
                  {{ text_automation_schema_ready }}
                  {% else %}
                  {{ text_automation_schema_missing }}
                  {% endif %}
                </span>
              </div>
              <div class="card-body">
                <p class="text-muted small mb-3">{{ text_automation_hint }}</p>
                <form action="{{ automation|replace({'&amp;':'&'}) }}" method="post" class="row g-3">
                  <input type="hidden" name="filter_scope" value="{{ chat_filters.filter_scope }}">
                  <input type="hidden" name="filter_status" value="{{ chat_filters.filter_status }}">
                  <input type="hidden" name="filter_priority" value="{{ chat_filters.filter_priority }}">
                  <input type="hidden" name="filter_department_id" value="{{ chat_filters.filter_department_id }}">
                  <input type="hidden" name="filter_queue_id" value="{{ chat_filters.filter_queue_id }}">
                  <input type="hidden" name="filter_assigned_user_id" value="{{ chat_filters.filter_assigned_user_id }}">
                  <input type="hidden" name="filter_sla_state" value="{{ chat_filters.filter_sla_state }}">
                  <input type="hidden" name="filter_tag" value="{{ chat_filters.filter_tag }}">
                  <input type="hidden" name="trend_window_days" value="{{ chat_filters.trend_window_days }}">
                  <input type="hidden" name="page" value="{{ page }}">

                  <div class="col-md-6">
                    <label class="form-label" for="input-automation-scheduler-enabled">{{ entry_automation_scheduler_enabled }}</label>
                    <select name="chat_automation_scheduler_enabled" id="input-automation-scheduler-enabled" class="form-select">
                      <option value="1"{% if chat_automation_settings.scheduler_enabled %} selected{% endif %}>{{ text_yes }}</option>
                      <option value="0"{% if not chat_automation_settings.scheduler_enabled %} selected{% endif %}>{{ text_no }}</option>
                    </select>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label" for="input-automation-scheduler-interval">{{ entry_automation_scheduler_interval }}</label>
                    <input type="number" min="1" max="1440" name="chat_automation_scheduler_interval_minutes" id="input-automation-scheduler-interval" class="form-control" value="{{ chat_automation_settings.scheduler_interval_minutes }}">
                  </div>
                  <div class="col-md-4">
                    <label class="form-label" for="input-automation-workload-enabled">{{ entry_automation_workload_enabled }}</label>
                    <select name="chat_automation_workload_balancing_enabled" id="input-automation-workload-enabled" class="form-select">
                      <option value="1"{% if chat_automation_settings.workload_balancing_enabled %} selected{% endif %}>{{ text_yes }}</option>
                      <option value="0"{% if not chat_automation_settings.workload_balancing_enabled %} selected{% endif %}>{{ text_no }}</option>
                    </select>
                  </div>
                  <div class="col-md-4">
