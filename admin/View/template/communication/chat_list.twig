                {% endif %}
                {% if supports_chat_tags %}
                <td class="text-left">{% if chat.tag_list %}{{ chat.tag_list }}{% else %}-{% endif %}</td>
                {% endif %}
                {% if supports_sla %}
                <td class="text-left"><span class="badge {{ chat.sla_summary_badge_class }}">{{ chat.sla_summary_label }}</span></td>
                {% endif %}
                {% if supports_engagement %}
                <td class="text-left"><span class="badge {{ chat.engagement_summary_badge_class }}">{{ chat.engagement_summary_label }}</span></td>
                {% endif %}
                <td class="text-right">{{ chat.last_message_date }}</td>
                <td class="text-right"><a href="{{ chat.view }}" data-bs-toggle="tooltip" title="{{ button_view }}" class="btn btn-primary"><i class="fa-solid fa-eye"></i></a></td>
              </tr>
              {% endfor %}
              {% else %}
              <tr>
                <td class="text-center" colspan="{{ total_columns }}">{{ text_no_results }}</td>
              </tr>
              {% endif %}
            </tbody>
          </table>
        </div>
        </form>
        {% else %}
        <div class="table-responsive">
          <table class="table table-bordered table-hover">
            <thead>
              <tr>
                <td class="text-left">{{ column_participants }}</td>
                <td class="text-left">{{ column_last_message }}</td>
                {% if supports_operational_meta %}
                <td class="text-left">{{ column_status }}</td>
                <td class="text-left">{{ column_priority }}</td>
                <td class="text-left">{{ column_assignee }}</td>
                {% endif %}
                {% if supports_chat_routing %}
                <td class="text-left">{{ column_department }}</td>
                <td class="text-left">{{ column_queue }}</td>
                {% endif %}
                {% if supports_chat_tags %}
                <td class="text-left">{{ column_tags }}</td>
                {% endif %}
                {% if supports_sla %}
                <td class="text-left">{{ column_sla }}</td>
                {% endif %}
                {% if supports_engagement %}
                <td class="text-left">{{ column_wait }}</td>
                {% endif %}
                <td class="text-right">{{ column_date }}</td>
                <td class="text-right">{{ column_action }}</td>
              </tr>
            </thead>
            <tbody>
              {% if chats %}
              {% for chat in chats %}
              <tr>
                <td class="text-left">{{ chat.participants }}</td>
                <td class="text-left">{{ chat.last_message }}</td>
                {% if supports_operational_meta %}
                <td class="text-left">{{ chat.status_label }}</td>
                <td class="text-left">{{ chat.priority_label }}</td>
                <td class="text-left">{% if chat.assigned_user_name %}{{ chat.assigned_user_name }}{% else %}{{ text_unassigned }}{% endif %}</td>
                {% endif %}
                {% if supports_chat_routing %}
                <td class="text-left">{% if chat.department_name %}{{ chat.department_name }}{% else %}{{ text_unrouted }}{% endif %}</td>
                <td class="text-left">{% if chat.queue_name %}{{ chat.queue_name }}{% else %}{{ text_unrouted }}{% endif %}</td>
                {% endif %}
                {% if supports_chat_tags %}
                <td class="text-left">{% if chat.tag_list %}{{ chat.tag_list }}{% else %}-{% endif %}</td>
                {% endif %}
                {% if supports_sla %}
                <td class="text-left"><span class="badge {{ chat.sla_summary_badge_class }}">{{ chat.sla_summary_label }}</span></td>
                {% endif %}
                {% if supports_engagement %}
                <td class="text-left"><span class="badge {{ chat.engagement_summary_badge_class }}">{{ chat.engagement_summary_label }}</span></td>
                {% endif %}
                <td class="text-right">{{ chat.last_message_date }}</td>
                <td class="text-right"><a href="{{ chat.view }}" data-bs-toggle="tooltip" title="{{ button_view }}" class="btn btn-primary"><i class="fa-solid fa-eye"></i></a></td>
              </tr>
              {% endfor %}
              {% else %}
              <tr>
                <td class="text-center" colspan="{{ total_columns }}">{{ text_no_results }}</td>
              </tr>
              {% endif %}
            </tbody>
          </table>
        </div>
        {% endif %}
        <div class="row">
          <div class="col-sm-6 text-left">{{ pagination }}</div>
          <div class="col-sm-6 text-right">{{ results }}</div>
        </div>
      </div>
    </div>
  </div>
</div>
{{ footer }}
{% if bulk_select_enabled %}
<script>
document.addEventListener('DOMContentLoaded', function() {
  var toggle = document.getElementById('input-check-all');

  if (!toggle) {
    return;
  }

  toggle.addEventListener('change', function() {
    document.querySelectorAll('.chat-select-item').forEach(function(item) {
      item.checked = toggle.checked;
    });
  });
});
</script>
{% endif %}
