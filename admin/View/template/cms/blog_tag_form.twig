{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end rms-page-actions">
        <button type="submit" form="form-tag" class="btn btn-primary" data-bs-toggle="tooltip" title="{{ button_save }}">
          <i class="fa-solid fa-floppy-disk"></i>
          <span>{{ button_save }}</span>
        </button>
        <a href="{{ cancel }}" class="btn btn-light" data-bs-toggle="tooltip" title="{{ button_cancel }}">
          <i class="fa-solid fa-reply"></i>
          <span>{{ button_cancel }}</span>
        </a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    {% if errors.warning %}
      <div class="alert alert-danger"><i class="fa-solid fa-circle-exclamation"></i> {{ errors.warning }}</div>
    {% endif %}

    <div class="card rms-admin-card">
      <div class="card-header">
        <i class="fa-solid fa-tags"></i>
        <span>{{ text_form }}</span>
      </div>
      <div class="card-body">
        <form action="{{ action }}" method="post" id="form-tag">
          <div class="row mb-3 required">
            <label class="col-sm-2 col-form-label" for="input-name">{{ entry_title }}</label>
            <div class="col-sm-10">
              <input type="text" name="name" value="{{ tag.name }}" id="input-name" class="form-control"/>
              {% if errors.name %}<div class="text-danger">{{ errors.name }}</div>{% endif %}
            </div>
          </div>
          <div class="row mb-3">
            <label class="col-sm-2 col-form-label" for="input-slug">{{ entry_slug }}</label>
            <div class="col-sm-10">
              <input type="text" name="slug" value="{{ tag.slug }}" id="input-slug" class="form-control"/>
            </div>
          </div>
          <div class="row mb-3">
            <label class="col-sm-2 col-form-label" for="input-status">{{ entry_status }}</label>
            <div class="col-sm-4">
              <select name="status" id="input-status" class="form-select">
                <option value="1" {{ tag.status ? 'selected' : '' }}>{{ text_enabled }}</option>
                <option value="0" {{ not tag.status ? 'selected' : '' }}>{{ text_disabled }}</option>
              </select>
            </div>
          </div>
          <div class="row mb-0">
            <label class="col-sm-2 col-form-label" for="input-sort">{{ entry_sort_order }}</label>
            <div class="col-sm-4">
              <input type="number" name="sort_order" value="{{ tag.sort_order }}" id="input-sort" class="form-control"/>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
{{ footer }}
