{{ header }}{{ column_left }}
<div id="content" data-testid="admin-landpage-builder-page">
  {% set rms_actions = [
    {
      tag: 'button',
      type: 'submit',
      form: 'form-builder',
      class: 'btn btn-primary',
      title: button_save,
      icon: 'fa-solid fa-floppy-disk',
      text: button_save
    },
    {
      href: edit_page,
      class: 'btn btn-light',
      title: button_cancel,
      icon: 'fa-solid fa-reply',
      text: button_cancel
    }
  ] %}
  {% include 'common/rms_page_header.twig' with {
    rms_heading_title: heading_title,
    rms_breadcrumbs: breadcrumbs,
    rms_actions: rms_actions
  } %}
  <div class="container-fluid">
    {% if success %}
      <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i> {{ success }}</div>
    {% endif %}
    {% if error_warning %}
      <div class="alert alert-danger"><i class="fa-solid fa-circle-exclamation"></i> {{ error_warning }}</div>
    {% endif %}

    {% if page.editor_mode != 'builder' %}
      <div class="alert alert-warning d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
        <div>
          <strong>{{ text_editor_builder }}</strong>
          <div>{{ text_builder_mode_notice }}</div>
        </div>
        <a href="{{ edit_page }}" class="btn btn-outline-dark btn-sm">{{ button_builder }}</a>
      </div>
    {% endif %}

    <div class="row g-4">
      <div class="col-xl-4">
        <div class="card rms-admin-card h-100">
          <div class="card-header">
            <i class="fa-solid fa-shapes"></i>
            <span>{{ text_builder_library }}</span>
          </div>
          <div class="card-body">
            <p class="text-muted mb-3">{{ text_builder_intro }}</p>
            <div class="d-grid gap-3">
              {% for type in block_types %}
                <article class="border rounded-3 p-3">
                  <div class="d-flex justify-content-between align-items-start gap-3">
                    <div>
                      <div class="fw-semibold">{{ type.label }}</div>
                      <div class="small text-muted mt-1">{{ type.description }}</div>
                    </div>
                    <a href="{{ type.add }}" class="btn btn-outline-primary btn-sm">{{ button_add_block }}</a>
                  </div>
                </article>
              {% endfor %}
            </div>
          </div>
        </div>
      </div>

      <div class="col-xl-4">
        <div class="card rms-admin-card h-100">
          <div class="card-header d-flex justify-content-between align-items-center gap-2">
            <span><i class="fa-solid fa-grip-vertical"></i> {{ text_builder_structure }}</span>
            <small class="text-muted">{{ text_builder_sort_help }}</small>
          </div>
          <div class="card-body">
            <form action="{{ save }}" method="post" id="form-builder">
              {% if blocks %}
                <div id="builder-structure" class="d-grid gap-3">
                  {% for block in blocks %}
                    <article class="card border shadow-sm builder-structure-item" data-block-id="{{ block.block_id }}">
                      <div class="card-body d-flex gap-3 align-items-start">
                        <button type="button" class="btn btn-light btn-sm builder-handle" aria-label="{{ text_builder_sort_help }}">
                          <i class="fa-solid fa-grip-vertical"></i>
                        </button>
                        <div class="flex-grow-1">
                          <input type="hidden" name="block_ids[]" value="{{ block.block_id }}" />
                          <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                            <strong>{{ block.label }}</strong>
                            <span class="badge text-bg-light text-dark">{{ block.type }}</span>
                          </div>
                          {% if block.summary %}
                            <div class="small text-muted">{{ block.summary }}</div>
                          {% endif %}
                        </div>
                        <div class="d-flex flex-wrap gap-2 justify-content-end">
                          <a href="{{ block.edit }}" class="btn btn-outline-primary btn-sm"><i class="fa-solid fa-pen"></i></a>
                          <a href="{{ block.duplicate }}" class="btn btn-outline-secondary btn-sm"><i class="fa-regular fa-copy"></i></a>
                          <a href="{{ block.delete }}" class="btn btn-outline-danger btn-sm" onclick="return confirm('{{ text_confirm }}');"><i class="fa-regular fa-trash-can"></i></a>
                        </div>
                      </div>
                    </article>
                  {% endfor %}
                </div>
              {% else %}
                <div class="rms-empty-state">{{ text_builder_no_blocks }}</div>
              {% endif %}
            </form>
          </div>
        </div>
      </div>

      <div class="col-xl-4">
        <div class="card rms-admin-card h-100">
          <div class="card-header">
            <i class="fa-solid fa-up-right-and-down-left-from-center"></i>
            <span>{{ text_builder_preview }}</span>
          </div>
          <div class="card-body">
            <div class="builder-preview-shell rms-catalog-shell">
              {% if preview_html %}
                {{ preview_html|raw }}
              {% else %}
                <div class="rms-catalog-empty">{{ text_builder_no_blocks }}</div>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<style>
  .builder-handle {
    cursor: move;
  }

  .builder-preview-shell {
    max-height: 78vh;
    overflow: auto;
    padding-right: 0.25rem;
  }

  .builder-structure-item.ui-sortable-helper {
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.18);
  }

  .builder-structure-item.ui-sortable-placeholder {
    visibility: visible !important;
    background: rgba(35, 161, 209, 0.08);
    border: 1px dashed rgba(35, 161, 209, 0.6);
    min-height: 90px;
  }
</style>
<script type="text/javascript">
  $('#builder-structure').sortable({
    handle: '.builder-handle',
    placeholder: 'ui-sortable-placeholder'
  });
</script>
{{ footer }}
