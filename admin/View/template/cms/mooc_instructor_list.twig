{{ header }}{{ column_left }}
<div id="content" data-testid="admin-mooc-instructor-list-page">
  {% set rms_actions = [
    {
      href: add,
      class: 'btn btn-primary',
      icon: 'fa-solid fa-plus',
      text: text_add,
      testid: 'admin-mooc-instructor-add-link'
    },
    {
      tag: 'button',
      type: 'submit',
      form: 'form-instructor',
      formaction: approve,
      class: 'btn btn-success',
      icon: 'fa-solid fa-check',
      text: button_approve
    },
    {
      tag: 'button',
      type: 'submit',
      form: 'form-instructor',
      formaction: delete,
      class: 'btn btn-danger',
      icon: 'fa-regular fa-trash-can',
      text: button_delete,
      onclick: "return confirm('Delete selected?');"
    }
  ] %}
  {% include 'common/rms_page_header.twig' with {
    rms_heading_title: heading_title,
    rms_breadcrumbs: breadcrumbs,
    rms_actions: rms_actions
  } %}
  <div class="container-fluid">
    {% if success %}
      <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i> {{ success }}</div>
    {% endif %}
    {% set rms_card_body %}
      <form id="form-instructor" method="post">
        <div class="rms-admin-table-responsive">
          <table class="table table-bordered table-hover align-middle">
            <thead>
              <tr>
                <th style="width:1%;" class="text-center"><input type="checkbox" onclick="$('input[name*=\\'selected\\']').prop('checked', this.checked);" /></th>
                <th>{{ column_name }}</th>
                <th>{{ column_headline }}</th>
                <th>{{ column_user }}</th>
                <th>{{ column_status }}</th>
                <th class="text-end">{{ column_action }}</th>
              </tr>
            </thead>
            <tbody>
              {% if instructors %}
                {% for instructor in instructors %}
                  <tr data-testid="admin-mooc-instructor-row" data-instructor-id="{{ instructor.instructor_id }}">
                    <td class="text-center"><input type="checkbox" name="selected[]" value="{{ instructor.instructor_id }}"></td>
                    <td>{{ instructor.name }}</td>
                    <td>{{ instructor.headline }}</td>
                    <td>{{ instructor.user_id }}</td>
                    <td>
                      {% if instructor.approved %}
                        <span class="badge text-bg-success rms-status-badge">{{ text_approved }}</span>
                      {% else %}
                        <span class="badge text-bg-warning rms-status-badge">{{ text_pending }}</span>
                      {% endif %}
                    </td>
                    <td class="text-end"><a href="{{ instructor.edit }}" class="btn btn-outline-primary btn-sm" data-testid="admin-mooc-instructor-edit-link"><i class="fa-solid fa-pen"></i></a></td>
                  </tr>
                {% endfor %}
              {% else %}
                <tr>
                  <td colspan="6" class="rms-empty-state">{{ text_no_results }}</td>
                </tr>
              {% endif %}
            </tbody>
          </table>
        </div>
      </form>
    {% endset %}
    {% include 'common/rms_admin_card.twig' with {
      rms_card_icon: 'fa-solid fa-users',
      rms_card_title: text_list,
      rms_card_body: rms_card_body
    } %}
  </div>
</div>

{{ footer }}
