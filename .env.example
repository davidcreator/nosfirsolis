# NosfirSolis Environment Variables
# Copy this file to .env and adjust values for each environment.

# Strong random secret for token encryption (required in production)
TOKEN_CIPHER_KEY=
# Optional key(s) used only for decrypt during rotation (comma-separated)
TOKEN_CIPHER_KEY_PREVIOUS=

# Comma-separated list of trusted proxy IPs/CIDRs
# Examples:
# TRUSTED_PROXIES=127.0.0.1,::1
# TRUSTED_PROXIES=10.0.0.0/8,192.168.0.0/16
TRUSTED_PROXIES=127.0.0.1,::1

# Comma-separated host allowlist (prevents Host header injection)
# Examples:
# ALLOWED_HOSTS=localhost,127.0.0.1,::1,nosfirsolis.local,app.example.com
ALLOWED_HOSTS=localhost,127.0.0.1,::1

# Keep blocked in production unless there is a justified internal integration
AUTOMATION_ALLOW_PRIVATE_WEBHOOK_ENDPOINTS=0
