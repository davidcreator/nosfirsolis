# NosfirSolis Environment Variables
# Copy this file to .env and adjust values for each environment.

# Runtime environment: development | production
APP_ENV=development

# Database connection (recommended via environment, not hardcoded files)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Optional privileged DB user for operational migrations (DDL)
# Keep application user without ALTER/CREATE in production.
DB_MIGRATION_HOST=127.0.0.1
DB_MIGRATION_PORT=3306
DB_MIGRATION_DATABASE=
DB_MIGRATION_USERNAME=
DB_MIGRATION_PASSWORD=
DB_MIGRATION_CHARSET=utf8mb4
DB_MIGRATION_COLLATION=utf8mb4_unicode_ci

# Mail delivery
# MAIL_DRIVER=php_mail|smtp
MAIL_DRIVER=php_mail
MAIL_FALLBACK_TO_PHP_MAIL=1
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=Solis
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
MAIL_SMTP_ENCRYPTION=tls
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=
MAIL_SMTP_AUTH=1
MAIL_SMTP_TIMEOUT=15
MAIL_SMTP_VERIFY_PEER=1

# Strong random secret for token encryption (required in production)
TOKEN_CIPHER_KEY=
# Optional key(s) used only for decrypt during rotation (comma-separated)
TOKEN_CIPHER_KEY_PREVIOUS=

# Comma-separated list of trusted proxy IPs/CIDRs
# Examples:
# TRUSTED_PROXIES=127.0.0.1,::1
# TRUSTED_PROXIES=10.0.0.0/8,192.168.0.0/16
TRUSTED_PROXIES=127.0.0.1,::1

# Comma-separated host allowlist (prevents Host header injection)
# Examples:
# ALLOWED_HOSTS=localhost,127.0.0.1,::1,nosfirsolis.local,app.example.com
# Production example: ALLOWED_HOSTS=app.example.com,www.example.com
ALLOWED_HOSTS=localhost,127.0.0.1,::1

# Keep disabled in production (legacy migration fallback only)
HOST_GUARD_COMPATIBILITY_MODE=0

# Keep blocked in production unless there is a justified internal integration
AUTOMATION_ALLOW_PRIVATE_WEBHOOK_ENDPOINTS=0

# Runtime schema mutations (CREATE/ALTER during requests):
# Secure-by-default: keep 0 in all environments.
# Enable 1 only for temporary local bootstrap/migration routines.
SECURITY_RUNTIME_SCHEMA_MUTATIONS=0

# Login protection behavior when security telemetry storage fails:
# 1 = fail-open (availability-first), 0 = fail-closed (security-first)
# Secure-by-default: keep 0 in all environments.
# Enable 1 only for temporary troubleshooting with explicit risk acceptance.
AUTH_FAIL_OPEN_ON_SECURITY_ERROR=0

# Global security headers (set to 0 only for troubleshooting)
SECURITY_HEADERS_ENABLED=1

# Content Security Policy (adjust according to your integrations)
# CONTENT_SECURITY_POLICY=default-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; object-src 'none'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https:; script-src 'self' 'unsafe-inline' https:; connect-src 'self' https:; font-src 'self' data: https:; frame-src 'self' https:;
# Legacy fallback only: enables unsafe-eval in default CSP when set to 1
CSP_ALLOW_UNSAFE_EVAL=0

# HSTS (HTTPS only). Keep disabled in development.
HSTS_ENABLED=0
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=1
HSTS_PRELOAD=0
